{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kairos IR",
  "oneOf": [
    {
      "$ref": "#/$defs/program"
    },
    {
      "$ref": "#/$defs/project"
    }
  ],
  "$defs": {
    "program": {
      "type": "object",
      "required": [
        "package",
        "module",
        "relative_path",
        "imports",
        "import_bindings",
        "context",
        "schemas",
        "enums",
        "type_aliases",
        "functions",
        "source_hash"
      ],
      "properties": {
        "package": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "relative_path": {
          "type": "string"
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "import_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/import_binding"
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        },
        "schemas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/schema"
          }
        },
        "enums": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/enum"
          }
        },
        "type_aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/type_alias"
          }
        },
        "functions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/function"
          }
        },
        "source_hash": {
          "type": "string"
        }
      }
    },
    "project": {
      "type": "object",
      "required": [
        "package",
        "packages",
        "modules",
        "source_hash"
      ],
      "properties": {
        "package": {
          "$ref": "#/$defs/package"
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/package_node"
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/program"
          }
        },
        "source_hash": {
          "type": "string"
        }
      }
    },
    "package": {
      "type": "object",
      "required": [
        "name",
        "version",
        "entry_file",
        "entry_module",
        "emit",
        "dependencies"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "entry_file": {
          "type": "string"
        },
        "entry_module": {
          "type": "string"
        },
        "emit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/package_dependency"
          }
        }
      }
    },
    "package_node": {
      "type": "object",
      "required": [
        "name",
        "version",
        "entry_file",
        "entry_module",
        "is_root",
        "dependencies"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "entry_file": {
          "type": "string"
        },
        "entry_module": {
          "type": "string"
        },
        "is_root": {
          "type": "boolean"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/package_dependency"
          }
        }
      }
    },
    "package_dependency": {
      "type": "object",
      "required": [
        "alias",
        "package",
        "path"
      ],
      "properties": {
        "alias": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "import_binding": {
      "type": "object",
      "required": [
        "module",
        "items"
      ],
      "properties": {
        "module": {
          "type": "string"
        },
        "alias": {
          "type": [
            "string",
            "null"
          ]
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/import_item"
          }
        }
      }
    },
    "import_item": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "alias": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "internal"
      ]
    },
    "schema": {
      "type": "object",
      "required": [
        "visibility",
        "name",
        "fields"
      ],
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "name": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "enum": {
      "type": "object",
      "required": [
        "visibility",
        "name",
        "variants"
      ],
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "name": {
          "type": "string"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "type_alias": {
      "type": "object",
      "required": [
        "visibility",
        "name",
        "target"
      ],
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "name": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      }
    },
    "function": {
      "type": "object",
      "required": [
        "visibility",
        "is_test",
        "name",
        "return_type",
        "params",
        "metadata",
        "body"
      ],
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "is_test": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "return_type": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/param"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "body": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statement"
          }
        }
      }
    },
    "param": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "describe",
        "tags",
        "requires",
        "ensures"
      ],
      "properties": {
        "describe": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expression"
          }
        },
        "ensures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expression"
          }
        }
      }
    },
    "statement": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "name",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "let"
            },
            "name": {
              "type": "string"
            },
            "value": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "return"
            },
            "value": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "condition",
            "then_branch"
          ],
          "properties": {
            "kind": {
              "const": "if"
            },
            "condition": {
              "$ref": "#/$defs/expression"
            },
            "then_branch": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/statement"
              }
            },
            "else_branch": {
              "$ref": "#/$defs/else_branch"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "expression"
          ],
          "properties": {
            "kind": {
              "const": "expr"
            },
            "expression": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    },
    "else_branch": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "statements"
          ],
          "properties": {
            "kind": {
              "const": "block"
            },
            "statements": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/statement"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "statement"
          ],
          "properties": {
            "kind": {
              "const": "if"
            },
            "statement": {
              "$ref": "#/$defs/statement"
            }
          }
        }
      ]
    },
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "literal"
            },
            "value": {
              "$ref": "#/$defs/literal"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "name"
          ],
          "properties": {
            "kind": {
              "const": "identifier"
            },
            "name": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "callee",
            "args"
          ],
          "properties": {
            "kind": {
              "const": "call"
            },
            "callee": {
              "type": "string"
            },
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "items"
          ],
          "properties": {
            "kind": {
              "const": "list"
            },
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "fields"
          ],
          "properties": {
            "kind": {
              "const": "object"
            },
            "fields": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/object_field"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "operator",
            "left",
            "right"
          ],
          "properties": {
            "kind": {
              "const": "binary"
            },
            "operator": {
              "type": "string"
            },
            "left": {
              "$ref": "#/$defs/expression"
            },
            "right": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    },
    "object_field": {
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/expression"
        }
      }
    },
    "literal": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "string"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "integer"
            },
            "value": {
              "type": "integer"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "float"
            },
            "value": {
              "type": "number"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "boolean"
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "null"
            }
          }
        }
      ]
    }
  }
}
